    .intro-grid, .process-layout, .team-grid, .contact-layout, .outcomes-grid, .partners-list { grid-template-columns: 1fr; gap: 3rem; }
    .micro-inset { display: none; }
    .gallery-strip, .gallery-strip-2 { grid-template-columns: 1fr; height: auto; }
