  }

  .partner-item:hover {
    border-color: rgba(74,158,154,0.4);
  }

  .partner-item h4 {
    font-size: 1rem;
    font-weight: 500;
    margin-bottom: 0.4rem;
  }

  .partner-item p {
    font-size: 0.88rem;
    color: rgba(240,236,228,0.5);
