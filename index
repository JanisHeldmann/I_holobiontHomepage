// ── TYPEWRITER ENGINE ──────────────────────────────────────
function typewrite(el, text, speed, onDone) {
  let i = 0;
  el.textContent = '';
  el.style.borderRightColor = 'var(--teal)';
  const tick = setInterval(() => {
    // Handle the italic "?" in hero: after comma space
    el.textContent = text.slice(0, i + 1);
    i++;
    if (i >= text.length) {
      clearInterval(tick);
      // blink cursor briefly then remove
      setTimeout(() => {
        el.classList.add('done');
        if (onDone) onDone();
      }, 600);
    }
  }, speed);
}

// Hero title — starts on load after fade-in delay
window.addEventListener('load', () => {
  const heroEl = document.getElementById('hero-tw');
  if (!heroEl) return;
  const raw = heroEl.dataset.text || '';
  // Rebuild with em tag for italic portion
  // We'll type the full string, then innerHTML-swap the "Holobiont?" part
  setTimeout(() => {
    heroEl.closest('h1').style.opacity = '1';
    typewriteHero(heroEl, raw, 80);
  }, 700);
});

function typewriteHero(el, text, speed) {
  // text = "I, Holobiont?"
  // After done, swap to styled version
  el.textContent = '';
  el.style.borderRightColor = 'var(--teal)';
  let i = 0;
  const tick = setInterval(() => {
    el.textContent = text.slice(0, i + 1);
    i++;
    if (i >= text.length) {
      clearInterval(tick);
      setTimeout(() => {
        el.textContent = text;
        el.classList.add('done');
      }, 500);
    }
  }, speed);
}

// Section h2 typewriter — fires when element enters viewport
const twH2s = document.querySelectorAll('.tw-h2');
const observed = new Set();

const h2Observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting && !observed.has(entry.target)) {
      observed.add(entry.target);
      const el = entry.target;
      const text = el.dataset.tw || '';
      // Small delay so it feels natural after scroll
      setTimeout(() => {
        el.style.display = 'inline';
        typewrite(el, text, 40, null);
      }, 120);
    }
  });
}, { threshold: 0.4 });

twH2s.forEach(el => {
  el.textContent = '';
  el.style.display = 'inline';
  el.style.borderRightColor = 'var(--teal)';
  h2Observer.observe(el);
});
</script>

<script>
// ── MICROBIOME ANIMATION ───────────────────────────────────
(function () {
  const canvas = document.getElementById('microbiome-canvas');
  const ctx = canvas.getContext('2d');

  function resize() {
    canvas.width = canvas.offsetWidth;
    canvas.height = canvas.offsetHeight;
  }
  resize();
  window.addEventListener('resize', () => { resize(); });

  // Fade in after a moment
  setTimeout(() => canvas.classList.add('visible'), 800);

  // Colour palette: teal, mauve, warm white — all semi-transparent
  const PALETTES = [
    'rgba(74,158,154,',   // teal
    'rgba(122,74,94,',    // mauve
    'rgba(197,185,168,',  // dust
    'rgba(46,102,99,',    // teal-dim
    'rgba(240,236,228,',  // off-white
  ];

  // ── Cell types ──────────────────────────────────────────
  class Microbe {
    constructor() { this.reset(true); }

    reset(init) {
      const W = canvas.width, H = canvas.height;
      this.x = Math.random() * W;
      this.y = init ? Math.random() * H : (Math.random() < 0.5 ? -60 : H + 60);
      this.type = Math.floor(Math.random() * 4); // 0=coccus, 1=bacillus, 2=spiral, 3=flagellate
      this.r = 4 + Math.random() * 18;
      this.color = PALETTES[Math.floor(Math.random() * PALETTES.length)];
      this.alpha = 0.04 + Math.random() * 0.18;
      this.vx = (Math.random() - 0.5) * 0.35;
      this.vy = (Math.random() - 0.5) * 0.35;
      this.rot = Math.random() * Math.PI * 2;
      this.vrot = (Math.random() - 0.5) * 0.008;
      this.pulse = Math.random() * Math.PI * 2;
      this.pulseSpeed = 0.008 + Math.random() * 0.015;
      // flagellum
      this.flagAngle = Math.random() * Math.PI * 2;
      this.flagWave = Math.random() * Math.PI * 2;
      this.flagLen = this.r * (2.5 + Math.random() * 2);
      // division progress (random chance of showing fission)
      this.dividing = Math.random() < 0.12;
      this.divProg = Math.random();
      this.divDir = Math.random() < 0.5 ? 1 : -1;
    }

    update() {
      this.x += this.vx;
      this.y += this.vy;
      this.rot += this.vrot;
      this.pulse += this.pulseSpeed;
      this.flagWave += 0.04;
      if (this.dividing) {
        this.divProg += 0.0008;
        if (this.divProg > 1) { this.dividing = false; this.divProg = 0; }
      }
      const W = canvas.width, H = canvas.height;
      if (this.x < -80 || this.x > W + 80 || this.y < -80 || this.y > H + 80) this.reset(false);
    }

    draw() {
      ctx.save();
      ctx.translate(this.x, this.y);
      ctx.rotate(this.rot);
      const pulse = 1 + 0.04 * Math.sin(this.pulse);
      const a = this.alpha;
      const col = this.color;

      if (this.type === 0) {
        // Coccus — round cell, sometimes in pairs (diplococcus)
        this.drawCoccus(col, a, pulse);
      } else if (this.type === 1) {
        // Bacillus — rod-shaped
        this.drawBacillus(col, a, pulse);
      } else if (this.type === 2) {
        // Spiral bacterium
        this.drawSpiral(col, a);
      } else {
        // Flagellate — cell with a whip-like tail
        this.drawFlagellate(col, a, pulse);
      }
      ctx.restore();
    }

    drawCoccus(col, a, pulse) {
      const r = this.r * pulse;
      if (this.dividing) {
        // Two cells pinching apart
        const sep = r * this.divProg * 0.8;
        for (let s of [-1, 1]) {
          ctx.beginPath();
          ctx.ellipse(s * sep, 0, r * (1 - this.divProg * 0.15), r, 0, 0, Math.PI * 2);
          ctx.strokeStyle = col + (a * 1.4).toFixed(2) + ')';
          ctx.lineWidth = 1.2;
          ctx.stroke();
          ctx.fillStyle = col + (a * 0.25) + ')';
          ctx.fill();
        }
      } else {
        ctx.beginPath();
        ctx.arc(0, 0, r, 0, Math.PI * 2);
        ctx.strokeStyle = col + (a * 1.6).toFixed(2) + ')';
        ctx.lineWidth = 1.2;
        ctx.stroke();
        ctx.fillStyle = col + (a * 0.18) + ')';
        ctx.fill();
        // inner nucleus suggestion
        ctx.beginPath();
        ctx.arc(r * 0.15, -r * 0.1, r * 0.3, 0, Math.PI * 2);
        ctx.fillStyle = col + (a * 0.3) + ')';
        ctx.fill();
      }
    }

    drawBacillus(col, a, pulse) {
      const rw = this.r * 0.45 * pulse;
      const rh = this.r * 1.7 * pulse;
      ctx.beginPath();
      ctx.ellipse(0, 0, rw, rh, 0, 0, Math.PI * 2);
      ctx.strokeStyle = col + (a * 1.5).toFixed(2) + ')';
      ctx.lineWidth = 1.1;
      ctx.stroke();
      ctx.fillStyle = col + (a * 0.15) + ')';
      ctx.fill();
      // endospore suggestion
      ctx.beginPath();
      ctx.ellipse(0, rh * 0.35, rw * 0.7, rw * 0.9, 0, 0, Math.PI * 2);
      ctx.fillStyle = col + (a * 0.35) + ')';
      ctx.fill();
    }

    drawSpiral(col, a) {
      const r = this.r;
      ctx.beginPath();
      const turns = 2.2 + Math.sin(this.pulse) * 0.3;
      for (let t = 0; t <= turns * Math.PI * 2; t += 0.12) {
        const decay = t / (turns * Math.PI * 2);
        const amp = r * (0.3 + 0.7 * (1 - decay * 0.4));
        const x = Math.cos(t) * amp * 0.6;
        const y = (t / (turns * Math.PI * 2)) * r * 2.6 - r * 1.3;
        t === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
      }
      ctx.strokeStyle = col + (a * 1.8).toFixed(2) + ')';
      ctx.lineWidth = 1.4;
      ctx.stroke();
    }

    drawFlagellate(col, a, pulse) {
      const r = this.r * pulse * 0.85;
      // body
      ctx.beginPath();
      ctx.ellipse(0, 0, r * 0.55, r, 0, 0, Math.PI * 2);
      ctx.strokeStyle = col + (a * 1.4).toFixed(2) + ')';
      ctx.lineWidth = 1.1;
      ctx.stroke();
      ctx.fillStyle = col + (a * 0.15) + ')';
      ctx.fill();
      // flagellum — sinuous wave
      ctx.beginPath();
      const steps = 28;
      const len = this.flagLen;
      for (let i = 0; i <= steps; i++) {
        const t = i / steps;
        const fx = t * len - len * 0.1;
        const fy = r + Math.sin(this.flagWave + t * Math.PI * 3.5) * (r * 0.5) * (1 - t * 0.4);
        i === 0 ? ctx.moveTo(fx * 0.7, fy * 0.9) : ctx.lineTo(fx * 0.7, fy * 0.9);
      }
      ctx.strokeStyle = col + (a * 1.1).toFixed(2) + ')';
      ctx.lineWidth = 0.9;
      ctx.stroke();
    }
  }

  // ── Connexion filaments ──────────────────────────────────
  // thin lines suggesting quorum sensing / biofilm connections
  function drawFilaments(microbes) {
    const maxDist = 140;
    for (let i = 0; i < microbes.length; i++) {
      for (let j = i + 1; j < microbes.length; j++) {
        const dx = microbes[i].x - microbes[j].x;
        const dy = microbes[i].y - microbes[j].y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < maxDist) {
          const a = (1 - dist / maxDist) * 0.06;
          ctx.beginPath();
          ctx.moveTo(microbes[i].x, microbes[i].y);
          // slight curve
          const mx = (microbes[i].x + microbes[j].x) / 2 + (Math.random() - 0.5) * 20;
          const my = (microbes[i].y + microbes[j].y) / 2 + (Math.random() - 0.5) * 20;
          ctx.quadraticCurveTo(mx, my, microbes[j].x, microbes[j].y);
          ctx.strokeStyle = `rgba(74,158,154,${a})`;
          ctx.lineWidth = 0.5;
          ctx.stroke();
        }
      }
    }
  }

  // ── Init population ─────────────────────────────────────
  const COUNT = 55;
  const microbes = Array.from({ length: COUNT }, () => new Microbe());

  // ── Render loop ──────────────────────────────────────────
  let frame = 0;
  function loop() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    frame++;
    // filaments every 3rd frame for perf
    if (frame % 3 === 0) drawFilaments(microbes);
    microbes.forEach(m => { m.update(); m.draw(); });
    requestAnimationFrame(loop);
  }
  loop();
})();
</script>

