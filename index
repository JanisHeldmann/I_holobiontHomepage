  }

  .timeline-item {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 3rem;
    margin-bottom: 3.5rem;
    position: relative;
    padding-left: 0;
  }

  .timeline-item::before {
    content: '';
    position: absolute;
    left: -4px; top: 12px;
    width: 9px; height: 9px;
    border-radius: 50%;
    background: var(--teal);
    border: 2px solid var(--black);
  }

  .timeline-date {
    font-family: 'DM Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.15em;
    color: var(--teal);
    text-transform: uppercase;
    padding-top: 0.2rem;
    text-align: right;
  }

  .timeline-content h3 {
    font-size: 1.1rem;
    font-weight: 500;
    margin-bottom: 0.5rem;
  }

  .timeline-content p {
    font-size: 0.95rem;
    color: rgba(240,236,228,0.6);
  }

  /* ── TEAM ── */
  #team {
    padding: 120px 0;
    background: #0f0f0f;
  }

  .team-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    margin-top: 4rem;
  }

  .team-member {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: 2rem;
    align-items: start;
  }

  .team-avatar {
    width: 140px;
    height: 140px;
    border-radius: 50%;
    overflow: hidden;
    border: 2px solid rgba(74,158,154,0.3);
