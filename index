<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>I, Holobiont? — A Moving Lecture Performance</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;1,400&family=DM+Mono:wght@300;400&family=Special+Elite&display=swap" rel="stylesheet">
<style>
  :root {
    --black: #0a0a0a;
    --off-white: #f0ece4;
    --warm-white: #f7f4ee;
    --teal: #4a9e9a;
    --teal-dim: #2e6663;
    --mauve: #7a4a5e;
    --dust: #c5b9a8;
    --text: #1a1a1a;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--black);
    color: var(--off-white);
    font-family: 'EB Garamond', Georgia, serif;
    font-size: 18px;
    line-height: 1.7;
    overflow-x: hidden;
  }

  /* ── NAV ── */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.2rem 3rem;
    background: rgba(10,10,10,0.85);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .nav-logo {
    font-family: 'DM Mono', monospace;
    font-size: 0.78rem;
    letter-spacing: 0.2em;
    color: var(--teal);
    text-transform: uppercase;
  }

  nav ul {
    list-style: none;
    display: flex;
    gap: 2.5rem;
  }

  nav a {
    font-family: 'DM Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--dust);
    text-decoration: none;
    transition: color 0.25s;
  }

  nav a:hover { color: var(--off-white); }

  /* ── HERO ── */
  .hero {
    min-height: 100vh;
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 0 2rem;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background-image: url('data:image/jpeg;base64,');
    background-size: cover;
    background-position: center 30%;
    filter: brightness(0.35);
    transform: scale(1.03);
    animation: slowzoom 20s ease-in-out infinite alternate;
  }

  @keyframes slowzoom {
    from { transform: scale(1.03); }
    to { transform: scale(1.08) translateX(-1%); }
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(10,10,10,1) 0%, rgba(10,10,10,0.3) 50%, rgba(10,10,10,0.1) 100%);
  }

  #microbiome-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    pointer-events: none;
    opacity: 0;
    transition: opacity 2s ease;
  }

  #microbiome-canvas.visible {
    opacity: 1;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 860px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero-eyebrow {
    font-family: 'DM Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--teal);
    margin-bottom: 1.5rem;
    opacity: 0;
    animation: fadeup 1s 0.3s forwards;
  }

  /* ── TYPEWRITER ── */
  .typewriter-wrap {
    display: inline-block;
    position: relative;
  }

  .typewriter-text {
    display: inline;
    border-right: 3px solid var(--teal);
    white-space: nowrap;
    overflow: hidden;
    animation: typeCursor 0.75s step-end infinite;
  }

  .typewriter-text.done {
    border-right-color: transparent;
    animation: none;
  }

  @keyframes typeCursor {
    0%, 100% { border-right-color: var(--teal); }
    50% { border-right-color: transparent; }
  }

  /* Section h2 typewriter */
  .tw-h2 {
    display: inline;
    font-family: 'Special Elite', 'Courier New', monospace;
    border-right: 2px solid var(--teal);
    white-space: nowrap;
    overflow: hidden;
  }
  .tw-h2.done {
    border-right-color: transparent;
  }

  .hero h1 {
    font-size: clamp(3.5rem, 8vw, 7.5rem);
    font-family: 'Special Elite', 'Courier New', monospace;
    font-weight: 400;
    line-height: 0.95;
    letter-spacing: 0.01em;
    margin-bottom: 1rem;
    opacity: 0;
    animation: fadeup 0.01s 0.5s forwards;
    overflow: hidden;
  }

  .hero h1 em {
    font-style: italic;
    color: var(--dust);
  }

  .hero-sub {
    font-size: 1.15rem;
    color: var(--dust);
    max-width: 540px;
    margin-bottom: 2.5rem;
    font-style: italic;
    opacity: 0;
    animation: fadeup 1s 0.75s forwards;
    text-align: center;
  }

  .hero-meta {
    font-family: 'DM Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.15em;
    color: rgba(255,255,255,0.4);
    text-transform: uppercase;
    opacity: 0;
    animation: fadeup 1s 1s forwards;
    text-align: center;
  }

  .hero-meta span {
    color: var(--teal);
    margin: 0 0.5rem;
  }

  .scroll-hint {
    position: absolute;
    bottom: 3vh;
    right: 5vw;
    z-index: 2;
    font-family: 'DM Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.25);
    writing-mode: vertical-rl;
    display: flex;
    align-items: center;
    gap: 1rem;
    animation: fadeup 1s 1.5s forwards;
    opacity: 0;
  }

  .scroll-hint::before {
    content: '';
    display: block;
    width: 1px;
    height: 60px;
    background: rgba(255,255,255,0.2);
    animation: scrollline 2s 2s ease-in-out infinite;
  }

  @keyframes scrollline {
    0%, 100% { transform: scaleY(1); opacity: 0.3; }
    50% { transform: scaleY(0.4); opacity: 0.8; }
  }

  @keyframes fadeup {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ── SECTIONS SHARED ── */
  section {
    position: relative;
  }

  .container {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 4rem;
  }

  .section-label {
    font-family: 'DM Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--teal);
    margin-bottom: 2.5rem;
  }

  h2 {
    font-size: clamp(2.2rem, 4vw, 3.5rem);
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.01em;
    margin-bottom: 2rem;
  }

  h3 {
    font-size: 1.4rem;
    font-weight: 500;
    margin-bottom: 0.8rem;
  }

  p {
    color: rgba(240,236,228,0.8);
    margin-bottom: 1.2rem;
  }

  /* ── INTRO ── */
  #intro {
    padding: 120px 0 80px;
    background: var(--black);
  }

  .intro-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: start;
  }

  .intro-image {
    position: relative;
  }

  .intro-image img {
    width: 100%;
    aspect-ratio: 3/4;
    object-fit: cover;
    object-position: center top;
    filter: grayscale(20%) contrast(1.05);
  }

  .micro-inset {
    position: absolute;
    bottom: -30px;
    right: -30px;
    width: 180px;
    height: 180px;
    border-radius: 50%;
    overflow: hidden;
    border: 3px solid var(--black);
  }

  .micro-inset img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .intro-text {
    padding-top: 3rem;
  }

  /* ── ABOUT ── */
  #about {
    padding: 100px 0;
    background: #0f0f0f;
  }

  .about-full {
    max-width: 780px;
    margin: 0 auto;
    text-align: center;
  }

  .about-full p {
    font-size: 1.2rem;
    line-height: 1.8;
    color: rgba(240,236,228,0.85);
  }

  /* ── OUTCOMES ── */
  #outcomes {
    padding: 100px 0;
    background: var(--black);
  }

  .outcomes-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    margin-top: 4rem;
  }

  .outcome-card {
    background: #111;
    padding: 3rem 2.5rem;
    position: relative;
    overflow: hidden;
  }

  .outcome-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: var(--teal);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s ease;
  }

  .outcome-card:hover::before { transform: scaleX(1); }

  .outcome-number {
    font-family: 'DM Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    color: var(--teal);
    margin-bottom: 1.5rem;
  }

  .outcome-card h3 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
    font-style: italic;
  }

  /* ── GALLERY ── */
  #gallery {
    padding: 0;
    background: var(--black);
  }

  .gallery-strip {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    height: 500px;
    gap: 2px;
  }

  .gallery-strip img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(15%);
    transition: filter 0.5s, transform 0.5s;
  }

  .gallery-strip img:hover {
    filter: grayscale(0%);
    transform: scale(1.02);
    z-index: 2;
    position: relative;
  }

  .gallery-strip-2 {
    display: grid;
    grid-template-columns: 1fr 1fr 2fr;
    height: 400px;
    gap: 2px;
    margin-top: 2px;
  }

  /* ── PROCESS ── */
  #process {
    padding: 120px 0;
    background: #0d0d0d;
  }

  .process-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: center;
  }

  .process-text p {
    font-size: 1.05rem;
    line-height: 1.85;
  }

  .process-image img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
  }

  /* ── TIMELINE ── */
  #timeline {
    padding: 100px 0;
    background: var(--black);
    overflow: hidden;
  }

  .timeline {
    margin-top: 4rem;
    position: relative;
